
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Конструктор пиццы</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: system-ui, Arial, sans-serif;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background: #fff;
            color: #222;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* Шапка */
        header {
            background: #fff;
            border-bottom: 1px solid #ddd;
            position: sticky;
            top: 0;
        }

        .header-inner {
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 70px;
        }

        .logo {
            font-weight: bold;
            font-size: 1.5rem;
            color: #d35400;
            text-decoration: none;
        }

        .nav-menu {
            display: flex;
            gap: 30px;
        }

        .nav-menu a {
            text-decoration: none;
            color: #333;
        }

        /* Hero */
        .hero {
            text-align: center;
            padding: 60px 0;
            background: #f9f9f9;
        }

        .hero h1 {
            font-size: 2rem;
            margin-bottom: 10px;
        }

        /* Конструктор */
        .constructor-grid {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 30px;
            padding: 40px 0;
        }

        /* Пицца */
        .pizza-visual {
            background: #fff;
            border-radius: 10px;
            padding: 30px;
            text-align: center;
            border: 1px solid #eee;
            margin-bottom: 30px;
        }

        .pizza-base {
            position: relative;
            width: 300px;
            height: 300px;
            background: #f7d9aa;
            border-radius: 50%;
            border: 8px solid #e6b87e;
            margin: 0 auto;
            overflow: hidden;
        }

        #toppingLayer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }

        .topping {
            position: absolute;
            border-radius: 50%;
            transform: translate(-50%, -50%);
        }

        .topping.sauce {
            background: #b3470c;
            width: 100%;
            height: 100%;
            top: 50%;
            left: 50%;
            opacity: 0.3;
        }

        .topping.cheese { background: #ffd966; width: 35px; height: 35px; border: 2px solid #e6b422; }
        .topping.pepperoni { background: #b33c3c; width: 32px; height: 32px; border: 2px solid #8b2c2c; }
        .topping.mushrooms { background: #a17a5c; width: 28px; height: 28px; border: 2px solid #6b4f36; }
        .topping.peppers { background: #5f9e5f; width: 30px; height: 30px; border: 2px solid #2d6b2d; }

        /* Ингредиенты */
        .ingredients-panel {
            background: #fff;
            border: 1px solid #eee;
            border-radius: 10px;
            padding: 20px;
        }

        .ingredient-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px;
            border-bottom: 1px solid #f0f0f0;
        }

        .ingredient-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .dot {
            width: 20px;
            height: 20px;
            border-radius: 50%;
        }

        .dot.sauce { background: #b3470c; opacity: 0.7; }
        .dot.cheese { background: #ffd966; border: 2px solid #e6b422; }
        .dot.pepperoni { background: #b33c3c; border: 2px solid #8b2c2c; }
        .dot.mushrooms { background: #a17a5c; border: 2px solid #6b4f36; }
        .dot.peppers { background: #5f9e5f; border: 2px solid #2d6b2d; }

        .price {
            color: #d35400;
            font-weight: 600;
            margin-left: 10px;
        }

        .counter {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .counter span {
            min-width: 20px;
            text-align: center;
            font-weight: 600;
        }

        .add-btn {
            background: #d35400;
            color: white;
            border: none;
            width: 30px;
            height: 30px;
            border-radius: 4px;
            font-size: 1.2rem;
            cursor: pointer;
        }

        .add-btn:disabled {
            background: #ccc;
            cursor: not-allowed;
        }

        /* Корзина */
        .cart {
            background: #fff;
            border: 1px solid #eee;
            border-radius: 10px;
            padding: 20px;
            position: sticky;
            top: 90px;
        }

        .cart h3 {
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #f0f0f0;
        }

        #selectedList {
            list-style: none;
            margin-bottom: 20px;
            min-height: 150px;
        }

        #selectedList li {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px dashed #eee;
        }

        .total {
            display: flex;
            justify-content: space-between;
            font-weight: bold;
            font-size: 1.2rem;
            margin: 20px 0;
            padding-top: 10px;
            border-top: 2px solid #d35400;
        }

        .cart-buttons {
            display: flex;
            gap: 10px;
        }

        .btn {
            flex: 1;
            padding: 10px;
            border: none;
            border-radius: 4px;
            font-weight: 600;
            cursor: pointer;
        }

        .btn-order {
            background: #d35400;
            color: white;
        }

        .btn-clear {
            background: #e0e0e0;
        }

        footer {
            background: #333;
            color: white;
            padding: 30px 0;
            text-align: center;
            margin-top: 40px;
        }

        @media (max-width: 768px) {
            .constructor-grid {
                grid-template-columns: 1fr;
            }
            .cart {
                position: static;
            }
            .pizza-base {
                width: 250px;
                height: 250px;
            }
        }

        @media (max-width: 320px) {
            .nav-menu { gap: 15px; }
            .hero h1 { font-size: 1.5rem; }
            .pizza-base { width: 200px; height: 200px; }
        }
    </style>
</head>
<body>
    <header>
        <div class="container header-inner">
            <a href="#" class="logo">PizzaBuilder</a>
            <nav class="nav-menu">
                <a href="#about">О нас</a>
                <a href="#constructor">Конструктор</a>
                <a href="#contacts">Контакты</a>
            </nav>
        </div>
    </header>

    <section id="about" class="hero">
        <div class="container">
            <h1>Собери свою идеальную пиццу</h1>
            <p>Выбери ингредиенты и получи свою уникальную комбинацию</p>
        </div>
    </section>

    <section id="constructor" class="container">
        <div class="constructor-grid">
            <div>
                <div class="pizza-visual">
                    <div class="pizza-base">
                        <div id="toppingLayer"></div>
                    </div>
                </div>

                <div class="ingredients-panel" id="ingredientsPanel"></div>
            </div>

            <div class="cart">
                <h3>Ваш заказ</h3>
                <ul id="selectedList"></ul>
                <div class="total">
                    <span>Итого:</span>
                    <span id="totalPrice">0 ₽</span>
                </div>
                <div class="cart-buttons">
                    <button class="btn btn-order" id="orderBtn">Заказать</button>
                    <button class="btn btn-clear" id="clearBtn">Очистить</button>
                </div>
            </div>
        </div>
    </section>

    <footer id="contacts">
        <div class="container">
            <p>PizzaBuilder — конструктор пиццы</p>
        </div>
    </footer>

    <script>
        (function() {
            // Данные строго по заданию: 5 ингредиентов
            const data = [
                { id: 'sauce', name: 'Соус', price: 25, color: 'sauce' },
                { id: 'cheese', name: 'Сыр', price: 30, color: 'cheese' },
                { id: 'pepperoni', name: 'Пепперони', price: 35, color: 'pepperoni' },
                { id: 'mushrooms', name: 'Грибы', price: 30, color: 'mushrooms' },
                { id: 'peppers', name: 'Перец', price: 28, color: 'peppers' }
            ];

            // Состояние
            let counts = { sauce: 0, cheese: 0, pepperoni: 0, mushrooms: 0, peppers: 0 };
            let total = 0;

            // DOM
            const panel = document.getElementById('ingredientsPanel');
            const list = document.getElementById('selectedList');
            const totalSpan = document.getElementById('totalPrice');
            const layer = document.getElementById('toppingLayer');
            const orderBtn = document.getElementById('orderBtn');
            const clearBtn = document.getElementById('clearBtn');

            // Координаты в пределах пиццы
            function getPos() {
                const r = 30 + Math.random() * 40;
                const angle = Math.random() * Math.PI * 2;
                return {
                    top: (50 + r * Math.sin(angle) * 0.7) + '%',
                    left: (50 + r * Math.cos(angle) * 0.7) + '%'
                };
            }

            // Отрисовка топпингов
            function drawPizza() {
                layer.innerHTML = '';
                if (counts.sauce) {
                    const el = document.createElement('div');
                    el.className = 'topping sauce';
                    layer.appendChild(el);
                }
                ['cheese', 'pepperoni', 'mushrooms', 'peppers'].forEach(type => {
                    for (let i = 0; i < counts[type]; i++) {
                        const el = document.createElement('div');
                        el.className = `topping ${type}`;
                        const pos = getPos();
                        el.style.top = pos.top;
                        el.style.left = pos.left;
                        layer.appendChild(el);
                    }
                });
            }

            // Обновление всего UI
            function refresh() {
                // Панель ингредиентов
                let html = '';
                data.forEach(ing => {
                    const cnt = counts[ing.id];
                    html += `
                        <div class="ingredient-item">
                            <div class="ingredient-info">
                                <span class="dot ${ing.color}"></span>
                                <span>${ing.name}</span>
                                <span class="price">${ing.price}₽</span>
                            </div>
                            <div class="counter">
                                <span>${cnt}</span>
                                <button class="add-btn" data-id="${ing.id}" ${cnt >= 3 ? 'disabled' : ''}>+</button>
                            </div>
                        </div>
                    `;
                });
                panel.innerHTML = html;

                // Список заказа
                let items = '';
                data.forEach(ing => {
                    const cnt = counts[ing.id];
                    if (cnt) items += `<li><span>${ing.name} x${cnt}</span> <span>${ing.price * cnt}₽</span></li>`;
                });
                list.innerHTML = items || '<li style="justify-content:center">Нет ингредиентов</li>';

                // Итого
                totalSpan.textContent = total + ' ₽';
                
                // Пицца
                drawPizza();
            }

            // Добавление
            function add(id) {
                const ing = data.find(d => d.id === id);
                if (counts[id] < 3) {
                    counts[id]++;
                    total += ing.price;
                    refresh();
                }
            }

            // Сброс
            function reset() {
                counts = { sauce: 0, cheese: 0, pepperoni: 0, mushrooms: 0, peppers: 0 };
                total = 0;
                refresh();
            }

            // События
            panel.addEventListener('click', e => {
                if (e.target.classList.contains('add-btn')) {
                    add(e.target.dataset.id);
                }
            });

            clearBtn.addEventListener('click', reset);
            orderBtn.addEventListener('click', () => {
                console.log({ items: counts, total });
                alert(`Заказ на сумму ${total} ₽`);
            });

            // Старт
            refresh();
        })();
    </script>
</body>
</html>
