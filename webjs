(function() {
    // Данные строго по заданию: 5 ингредиентов
    const data = [
        { id: 'sauce', name: 'Соус', price: 25, color: 'sauce' },
        { id: 'cheese', name: 'Сыр', price: 30, color: 'cheese' },
        { id: 'pepperoni', name: 'Пепперони', price: 35, color: 'pepperoni' },
        { id: 'mushrooms', name: 'Грибы', price: 30, color: 'mushrooms' },
        { id: 'peppers', name: 'Перец', price: 28, color: 'peppers' }
    ];

    // Состояние
    let counts = { sauce: 0, cheese: 0, pepperoni: 0, mushrooms: 0, peppers: 0 };
    let total = 0;

    // DOM элементы
    const panel = document.getElementById('ingredientsPanel');
    const list = document.getElementById('selectedList');
    const totalSpan = document.getElementById('totalPrice');
    const layer = document.getElementById('toppingLayer');
    const orderBtn = document.getElementById('orderBtn');
    const clearBtn = document.getElementById('clearBtn');

    // Функция получения случайных координат в пределах пиццы
    function getPosition() {
        const r = 30 + Math.random() * 40; // расстояние от центра
        const angle = Math.random() * Math.PI * 2;
        return {
            top: (50 + r * Math.sin(angle) * 0.7) + '%',
            left: (50 + r * Math.cos(angle) * 0.7) + '%'
        };
    }

    // Отрисовка ингредиентов на пицце
    function drawPizza() {
        layer.innerHTML = '';
        
        // Соус (один слой)
        if (counts.sauce) {
            const el = document.createElement('div');
            el.className = 'topping sauce';
            layer.appendChild(el);
        }
        
        // Сыр
        for (let i = 0; i < counts.cheese; i++) {
            const el = document.createElement('div');
            el.className = 'topping cheese';
            const pos = getPosition();
            el.style.top = pos.top;
            el.style.left = pos.left;
            layer.appendChild(el);
        }
        
        // Пепперони
        for (let i = 0; i < counts.pepperoni; i++) {
            const el = document.createElement('div');
            el.className = 'topping pepperoni';
            const pos = getPosition();
            el.style.top = pos.top;
            el.style.left = pos.left;
            layer.appendChild(el);
        }
        
        // Грибы
        for (let i = 0; i < counts.mushrooms; i++) {
            const el = document.createElement('div');
            el.className = 'topping mushrooms';
            const pos = getPosition();
            el.style.top = pos.top;
            el.style.left = pos.left;
            layer.appendChild(el);
        }
        
        // Перец
        for (let i = 0; i < counts.peppers; i++) {
            const el = document.createElement('div');
            el.className = 'topping peppers';
            const pos = getPosition();
            el.style.top = pos.top;
            el.style.left = pos.left;
            layer.appendChild(el);
        }
    }

    // Обновление панели ингредиентов
    function updateIngredientsPanel() {
        let html = '';
        data.forEach(ing => {
            const cnt = counts[ing.id];
            html += `
                <div class="ingredient-item">
                    <div class="ingredient-info">
                        <span class="dot ${ing.color}"></span>
                        <span>${ing.name}</span>
                        <span class="price">${ing.price}₽</span>
                    </div>
                    <div class="counter">
                        <span>${cnt}</span>
                        <button class="add-btn" data-id="${ing.id}" ${cnt >= 3 ? 'disabled' : ''}>+</button>
                    </div>
                </div>
            `;
        });
        panel.innerHTML = html;
    }

    // Обновление списка заказа
    function updateOrderList() {
        let items = '';
        data.forEach(ing => {
            const cnt = counts[ing.id];
            if (cnt > 0) {
                items += `<li><span>${ing.name} x${cnt}</span> <span>${ing.price * cnt}₽</span></li>`;
            }
        });
        list.innerHTML = items || '<li style="justify-content:center">Нет ингредиентов</li>';
    }

    // Полное обновление интерфейса
    function refreshUI() {
        updateIngredientsPanel();
        updateOrderList();
        totalSpan.textContent = total + ' ₽';
        drawPizza();
    }

    // Добавление ингредиента
    function addIngredient(id) {
        const ing = data.find(d => d.id === id);
        if (!ing) return;
        
        if (counts[id] < 3) {
            counts[id]++;
            total += ing.price;
            refreshUI();
        }
    }

    // Сброс всех ингредиентов
    function resetAll() {
        counts = { sauce: 0, cheese: 0, pepperoni: 0, mushrooms: 0, peppers: 0 };
        total = 0;
        refreshUI();
    }

    // Обработка заказа
    function handleOrder() {
        const order = {
            items: data.filter(ing => counts[ing.id] > 0).map(ing => ({
                name: ing.name,
                quantity: counts[ing.id],
                price: ing.price,
                total: ing.price * counts[ing.id]
            })),
            total: total
        };
        
        console.log('Заказ:', order);
        alert(`Заказ оформлен! Сумма: ${total} ₽`);
    }

    // Навешивание обработчиков событий
    function setupEventListeners() {
        panel.addEventListener('click', (e) => {
            if (e.target.classList.contains('add-btn')) {
                addIngredient(e.target.dataset.id);
            }
        });

        clearBtn.addEventListener('click', resetAll);
        orderBtn.addEventListener('click', handleOrder);
    }

    // Инициализация
    function init() {
        refreshUI();
        setupEventListeners();
    }

    // Запуск
    init();
})();
