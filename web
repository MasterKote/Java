<body>
    <div class="container">
        <h1>ПР10: Анимация перемещения объекта по прямой</h1>
        
        <div class="description">
            <p>Анимируйте объект, перемещая его из начальной точки в конечную точку по кратчайшему пути (по прямой).</p>
            <p>Используйте клики мыши для выбора начальной и конечной точек, затем нажмите "Запустить анимацию".</p>
        </div>
        
        <div class="controls">
            <button id="startBtn" class="button">Выбрать начальную точку (кликните в области анимации)</button>
            <button id="resetBtn" class="button">Сбросить точки</button>
            <button id="animateBtn" class="button" disabled>Запустить анимацию</button>
        </div>
        
        <div class="coordinates-container">
            <div class="coordinate-box">
                <h3>Координаты курсора</h3>
                <div class="coordinate">X: <span id="mouseX">0</span></div>
                <div class="coordinate">Y: <span id="mouseY">0</span></div>
            </div>
            
            <div class="coordinate-box">
                <h3>Начальная точка (x1; y1)</h3>
                <div class="coordinate">X: <span id="startX">не выбрано</span></div>
                <div class="coordinate">Y: <span id="startY">не выбрано</span></div>
            </div>
            
            <div class="coordinate-box">
                <h3>Конечная точка (x2; y2)</h3>
                <div class="coordinate">X: <span id="endX">не выбрано</span></div>
                <div class="coordinate">Y: <span id="endY">не выбрано</span></div>
            </div>
        </div>
        
        <div id="animation-area">
            <div id="animated-object"></div>
            <!-- Линия и точки будут добавлены через JavaScript -->
        </div>
        
        <div class="status" id="status">
            Готов к выбору начальной точки. Кликните в области анимации.
        </div>
        
        <div class="instructions">
            <h3>Инструкция:</h3>
            <ol>
                <li>Кликните в области анимации, чтобы выбрать начальную точку (x1; y1).</li>
                <li>Кликните в области анимации второй раз, чтобы выбрать конечную точку (x2; y2).</li>
                <li>Нажмите кнопку "Запустить анимацию", чтобы начать движение объекта по прямой линии.</li>
                <li>Используйте кнопку "Сбросить точки", чтобы начать заново.</li>
                <li>Координаты курсора отображаются в реальном времени.</li>
            </ol>
        </div>
    </div>

    <script>
        // Элементы DOM
        const animationArea = document.getElementById('animation-area');
        const animatedObject = document.getElementById('animated-object');
        const mouseXElement = document.getElementById('mouseX');
        const mouseYElement = document.getElementById('mouseY');
        const startXElement = document.getElementById('startX');
        const startYElement = document.getElementById('startY');
        const endXElement = document.getElementById('endX');
        const endYElement = document.getElementById('endY');
        const startBtn = document.getElementById('startBtn');
        const resetBtn = document.getElementById('resetBtn');
        const animateBtn = document.getElementById('animateBtn');
        const statusElement = document.getElementById('status');
        
        // Переменные состояния
        let startPoint = null;
        let endPoint = null;
        let animationInterval = null;
        let isAnimating = false;
        let step = 0;
        let totalSteps = 100; // Количество шагов анимации
        let selectingStartPoint = true;
        
        // Инициализация
        function init() {
            // Начальное положение объекта в центре
            const centerX = animationArea.offsetWidth / 2;
            const centerY = animationArea.offsetHeight / 2;
            animatedObject.style.left = `${centerX}px`;
            animatedObject.style.top = `${centerY}px`;
            
            // Добавление обработчиков событий
            window.addEventListener('mousemove', handleMouseMove);
            animationArea.addEventListener('click', handleAreaClick);
            startBtn.addEventListener('click', handleStartClick);
            resetBtn.addEventListener('click', resetPoints);
            animateBtn.addEventListener('click', startAnimation);
            
            updateStatus();
        }
        
        // Обработчик движения мыши
        function handleMouseMove(event) {
            // Получаем координаты мыши относительно области анимации
            const rect = animationArea.getBoundingClientRect();
            const mouseX = event.clientX - rect.left;
            const mouseY = event.clientY - rect.top;
            
            // Обновляем отображение координат
            mouseXElement.textContent = Math.round(mouseX);
            mouseYElement.textContent = Math.round(mouseY);
        }
        
        // Обработчик клика по области анимации
        function handleAreaClick(event) {
            if (isAnimating) return;
            
            const rect = animationArea.getBoundingClientRect();
            const x = event.clientX - rect.left;
            const y = event.clientY - rect.top;
            
            if (selectingStartPoint) {
                startPoint = { x, y };
                startXElement.textContent = Math.round(x);
                startYElement.textContent = Math.round(y);
                
                // Создаем визуальную точку
                createPoint(x, y, 'start-point', 'Начальная точка');
                
                selectingStartPoint = false;
                startBtn.textContent = 'Выбрать конечную точку (кликните в области анимации)';
                statusElement.textContent = 'Начальная точка выбрана. Теперь выберите конечную точку.';
            } else {
                endPoint = { x, y };
                endXElement.textContent = Math.round(x);
                endYElement.textContent = Math.round(y);
                
                // Создаем визуальную точку
                createPoint(x, y, 'end-point', 'Конечная точка');
                
                // Рисуем линию между точками
                drawLine();
                
                selectingStartPoint = true;
                startBtn.textContent = 'Изменить начальную точку';
                animateBtn.disabled = false;
                statusElement.textContent = 'Обе точки выбраны. Нажмите "Запустить анимацию".';
            }
            
            updateStatus();
        }
        
        // Обработчик кнопки выбора начальной точки
        function handleStartClick() {
            if (isAnimating) return;
            
            selectingStartPoint = true;
            startBtn.textContent = 'Выбрать начальную точку (кликните в области анимации)';
            statusElement.textContent = 'Кликните в области анимации, чтобы выбрать начальную точку.';
            
            // Удаляем существующие точки и линию
            removePointsAndLine();
            
            // Сбрасываем выбранные точки
            startPoint = null;
            endPoint = null;
            startXElement.textContent = 'не выбрано';
            startYElement.textContent = 'не выбрано';
            endXElement.textContent = 'не выбрано';
            endYElement.textContent = 'не выбрано';
            
            animateBtn.disabled = true;
        }
        
        // Создание визуальной точки
        function createPoint(x, y, className, label) {
            // Удаляем старую точку того же типа
            const oldPoints = document.querySelectorAll(`.${className}`);
            oldPoints.forEach(point => point.remove());
            
            // Создаем точку
            const point = document.createElement('div');
            point.classList.add('point', className);
            point.style.left = `${x}px`;
            point.style.top = `${y}px`;
            animationArea.appendChild(point);
            
            // Создаем подпись
            const labelElement = document.createElement('div');
            labelElement.classList.add('point-label');
            labelElement.textContent = label;
            labelElement.style.left = `${x}px`;
            labelElement.style.top = `${y}px`;
            animationArea.appendChild(labelElement);
        }
        
        // Рисование линии между точками
        function drawLine() {
            // Удаляем старую линию
            const oldLine = document.getElementById('line');
            if (oldLine) oldLine.remove();
            
            if (!startPoint || !endPoint) return;
            
            // Вычисляем длину и угол линии
            const dx = endPoint.x - startPoint.x;
            const dy = endPoint.y - startPoint.y;
            const length = Math.sqrt(dx * dx + dy * dy);
            const angle = Math.atan2(dy, dx) * (180 / Math.PI);
            
            // Создаем линию
            const line = document.createElement('div');
            line.id = 'line';
            line.style.left = `${startPoint.x}px`;
            line.style.top = `${startPoint.y}px`;
            line.style.width = `${length}px`;
            line.style.transform = `rotate(${angle}deg)`;
            
            animationArea.appendChild(line);
        }
        
        // Удаление точек и линии
        function removePointsAndLine() {
            const points = document.querySelectorAll('.point, .point-label');
            points.forEach(point => point.remove());
            
            const line = document.getElementById('line');
            if (line) line.remove();
        }
        
        // Сброс точек
        function resetPoints() {
            if (isAnimating) {
                stopAnimation();
            }
            
            selectingStartPoint = true;
            startPoint = null;
            endPoint = null;
            
            startXElement.textContent = 'не выбрано';
            startYElement.textContent = 'не выбрано';
            endXElement.textContent = 'не выбрано';
            endYElement.textContent = 'не выбрано';
            
            startBtn.textContent = 'Выбрать начальную точку (кликните в области анимации)';
            animateBtn.disabled = true;
            
            removePointsAndLine();
            
            // Возвращаем объект в центр
            const centerX = animationArea.offsetWidth / 2;
            const centerY = animationArea.offsetHeight / 2;
            animatedObject.style.left = `${centerX}px`;
            animatedObject.style.top = `${centerY}px`;
            
            updateStatus();
        }
        
        // Запуск анимации
        function startAnimation() {
            if (!startPoint || !endPoint || isAnimating) return;
            
            isAnimating = true;
            step = 0;
            
            // Перемещаем объект в начальную точку
            animatedObject.style.left = `${startPoint.x}px`;
            animatedObject.style.top = `${startPoint.y}px`;
            
            // Отключаем кнопки во время анимации
            startBtn.disabled = true;
            animateBtn.disabled = true;
            resetBtn.disabled = true;
            
            // Рассчитываем параметры прямой
            // Уравнение прямой: y = kx + b
            const k = (endPoint.y - startPoint.y) / (endPoint.x - startPoint.x);
            const b = startPoint.y - k * startPoint.x;
            
            // Рассчитываем шаги для анимации
            const dx = (endPoint.x - startPoint.x) / totalSteps;
            const dy = (endPoint.y - startPoint.y) / totalSteps;
            
            statusElement.textContent = 'Анимация выполняется...';
            
            // Запускаем анимацию с помощью setInterval
            animationInterval = setInterval(() => {
                step++;
                
                // Вычисляем новую позицию
                // Можно использовать два метода: линейную интерполяцию по шагам или уравнение прямой
                // Используем линейную интерполяцию для более плавного движения
                const newX = startPoint.x + dx * step;
                const newY = startPoint.y + dy * step;
                
                // Альтернативно, используем уравнение прямой:
                // const newX = startPoint.x + dx * step;
                // const newY = k * newX + b;
                
                // Устанавливаем новую позицию объекта
                animatedObject.style.left = `${newX}px`;
                animatedObject.style.top = `${newY}px`;
                
                // Проверяем, достигли ли конечной точки
                if (step >= totalSteps) {
                    stopAnimation();
                    animatedObject.style.left = `${endPoint.x}px`;
                    animatedObject.style.top = `${endPoint.y}px`;
                    statusElement.textContent = 'Анимация завершена! Объект достиг конечной точки.';
                }
            }, 20); // 50 FPS
        }
        
        // Остановка анимации
        function stopAnimation() {
            if (animationInterval) {
                clearInterval(animationInterval);
                animationInterval = null;
            }
            
            isAnimating = false;
            
            // Включаем кнопки
            startBtn.disabled = false;
            animateBtn.disabled = false;
            resetBtn.disabled = false;
        }
        
        // Обновление статуса
        function updateStatus() {
            if (isAnimating) {
                statusElement.textContent = 'Анимация выполняется...';
            } else if (!startPoint) {
                statusElement.textContent = 'Готов к выбору начальной точки. Кликните в области анимации.';
            } else if (!endPoint) {
                statusElement.textContent = 'Начальная точка выбрана. Теперь выберите конечную точку.';
            } else {
                statusElement.textContent = 'Обе точки выбраны. Нажмите "Запустить анимацию".';
            }
        }
        
        // Инициализация при загрузке страницы
        window.addEventListener('DOMContentLoaded', init);
    </script>
</body>
